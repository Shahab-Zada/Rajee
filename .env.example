# ========================================
# RAJEE WEB APP - ENVIRONMENT VARIABLES
# Next.js Web Application Configuration
# ========================================
# 
# INSTRUCTIONS:
# 1. Copy this file to .env.local
# 2. Fill in your actual Firebase credentials
# 3. Never commit .env.local to git
#

# ========================================
# FIREBASE CONFIGURATION (Required)
# Get these from Firebase Console: https://console.firebase.google.com
# Project Settings > General > Your apps > Web app
# ========================================

NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyCMUYhUr-PjEmvwMcDydyQLpVeWc6vrROk
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=rajee-198a5.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=rajee-198a5
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=rajee-198a5.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=133679087476
NEXT_PUBLIC_FIREBASE_APP_ID=1:133679087476:web:YOUR_WEB_APP_ID
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-YOUR_MEASUREMENT_ID
NEXT_PUBLIC_FIREBASE_DATABASE_URL=https://rajee-198a5-default-rtdb.firebaseio.com

# ========================================
# FIREBASE ADMIN SDK (Server-side only)
# Get this from Firebase Console > Project Settings > Service Accounts
# Generate new private key and paste the entire JSON here
# ========================================

FIREBASE_SERVICE_ACCOUNT_KEY='{"type":"service_account","project_id":"rajee-198a5","private_key_id":"...","private_key":"...","client_email":"...","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"..."}'

# Alternative: Individual fields (if you prefer)
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@rajee-198a5.iam.gserviceaccount.com

# ========================================
# DOMAIN CONFIGURATION
# ========================================

NEXT_PUBLIC_DOMAIN=rajee-sa.com
NEXT_PUBLIC_API_URL=https://api.rajee-sa.com

# ========================================
# OPTIONAL: External Services
# ========================================

# SendGrid (for email notifications)
# SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxx

# Vercel Analytics
# NEXT_PUBLIC_VERCEL_ANALYTICS_ID=xxxxxxxxxxxxxxxxxxxxx

# Google Maps (if using location features)
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=xxxxxxxxxxxxxxxxxxxxx

# ========================================
# DEVELOPMENT SETTINGS
# ========================================

# NODE_ENV is automatically set by Next.js
# development | production | test

# ========================================
# NOTES:
# - NEXT_PUBLIC_ prefix: Available in browser
# - No prefix: Server-side only (more secure)
# - For production, set these in Vercel/hosting dashboard
# ========================================